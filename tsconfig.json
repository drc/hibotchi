{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals", "@cloudflare/vitest-pool-workers"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["worker-configuration.d.ts", "src/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts", "vitest.config.ts"]
}
