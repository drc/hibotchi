{
  "name": "hibotchi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --test-scheduled",
    "deploy": "wrangler deploy",
    "check": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply hibotchi --local",
    "db:migrate:remote": "wrangler d1 migrations apply hibotchi --remote",
    "register:commands": "node --env-file=.dev.vars --import tsx scripts/register-commands.ts"
  },
  "dependencies": {
    "hono": "^4.8.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.30",
    "@types/node": "^25.5.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.12.0"
  }
}
